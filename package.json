    "pino": "10.3.1",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.0.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.0.0",
    "neostandard": "^0.13.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
