{
  "name": "paperclaw-query",
  "description": "Query PaperClaw AI agents — tax questions, medical info, form filling, document search",
  "version": "0.1.0",
  "triggers": [
    "cuánto IVA",
    "how much tax",
    "my medications",
    "fill this form",
    "fill the PDF",
    "rellena este modelo",
    "what documents",
    "qué documentos",
    "mis facturas",
    "mis medicamentos",
    "prepare declaration",
    "prepara la declaración"
  ],
  "input": {
    "message": "user question or instruction (required)",
    "agent": "optional: gestor|doctor|id_docs (auto-detected if omitted)",
    "file": "optional PDF form to fill"
  }
}
