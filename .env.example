# ── Postgres ─────────────────────────────────────────────────────────────────
# Single password used for both the paperless and gestor DB users
POSTGRES_PASSWORD=changeme

# ── Paperless-ngx ────────────────────────────────────────────────────────────
PAPERLESS_SECRET_KEY=changeme-generate-a-long-random-string
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=changeme
# Public URL paperless is reachable at (used for links in notifications)
PAPERLESS_URL=http://localhost:8000
# Port exposed on host
PAPERLESS_PORT=8000
# API token — generate after first boot:
#   docker compose exec paperless python manage.py drf_create_token admin
PAPERLESS_API_TOKEN=

# ── OpenClaw ─────────────────────────────────────────────────────────────────
# Generate any random string, e.g.: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=changeme-random-secret
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
# Set to 1 to allow unencrypted local WS (fine for LAN/Docker)
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1

# ── Claude / Anthropic ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Gestor ───────────────────────────────────────────────────────────────────
# (no extra vars yet — added as we build each feature)
